<Window x:Class="SilaLesaWpfApp.View.Window.AdminWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Администратор — Сила леса" 
        Height="650" Width="950"
        MinHeight="550" MinWidth="800"
        WindowStartupLocation="CenterScreen"
        Background="#E8F5E9">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель -->
        <StackPanel Grid.Row="0" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right"
                    Margin="10">
            <Button x:Name="btnRefreshAll" 
                    Content="Обновить всё" 
                    Style="{StaticResource ActionButton}"
                    Click="btnRefreshAll_Click"/>
            <Button x:Name="btnLogout" 
                    Content="Выйти" 
                    Style="{StaticResource ActionButton}"
                    Click="btnLogout_Click"/>
        </StackPanel>

        <!-- Вкладки -->
        <TabControl x:Name="tabControl" 
                    Grid.Row="1" Grid.RowSpan="2"
                    Style="{StaticResource CampTabControl}"
                    Margin="10,0,10,10">

            <!-- Пользователи и роли -->
            <TabItem Header="Пользователи и роли">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Добавить роль -->
                        <GroupBox Header="Добавить роль" 
                                  Style="{StaticResource CampGroupBox}"
                                  Grid.Row="0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Название роли:" 
                                           VerticalAlignment="Center" 
                                           Margin="5"/>
                                <TextBox x:Name="txtRoleName" 
                                         Width="200" 
                                         Style="{StaticResource CampTextBox}"/>
                                <Button x:Name="btnAddRole" 
                                        Content="Добавить роль" 
                                        Style="{StaticResource ActionButton}"
                                        Click="btnAddRole_Click"/>
                            </StackPanel>
                        </GroupBox>

                        <!-- Роли и Пользователи -->
                        <Grid Grid.Row="1" Margin="0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="300"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <GroupBox Header="Роли" 
                                      Style="{StaticResource CampGroupBox}"
                                      Grid.Column="0">
                                <DataGrid x:Name="dgRoles" 
                                          Style="{StaticResource CampDataGrid}"
                                          Height="200"/>
                            </GroupBox>

                            <GroupBox Header="Пользователи" 
                                      Style="{StaticResource CampGroupBox}"
                                      Grid.Column="1">
                                <DataGrid x:Name="dgUsers" 
                                          Style="{StaticResource CampDataGrid}"
                                          Height="200"
                                          SelectionChanged="dgUsers_SelectionChanged"/>
                            </GroupBox>
                        </Grid>

                        <!-- Добавить пользователя -->
                        <GroupBox Header="Добавить пользователя" 
                                  Style="{StaticResource CampGroupBox}"
                                  Grid.Row="2">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Логин:" 
                                           VerticalAlignment="Center" 
                                           Margin="5"/>
                                <TextBox x:Name="txtNewLogin" 
                                         Width="120" 
                                         Style="{StaticResource CampTextBox}"/>

                                <TextBlock Text="Пароль:" 
                                           VerticalAlignment="Center" 
                                           Margin="10,5,5,5"/>
                                <PasswordBox x:Name="txtNewPassword" 
                                             Width="120" 
                                             Height="28"
                                             Padding="5,3"/>

                                <TextBlock Text="Роль:" 
                                           VerticalAlignment="Center" 
                                           Margin="10,5,5,5"/>
                                <ComboBox x:Name="cmbNewUserRole" 
                                          Width="120" 
                                          Style="{StaticResource CampComboBox}"
                                          DisplayMemberPath="RoleName"
                                          SelectedValuePath="RoleID"/>

                                <Button x:Name="btnAddUser" 
                                        Content="Добавить" 
                                        Style="{StaticResource ActionButton}"
                                        Click="btnAddUser_Click"/>
                            </StackPanel>
                        </GroupBox>

                        <!-- Действия с пользователем -->
                        <GroupBox Header="Действия с выбранным пользователем" 
                                  Style="{StaticResource CampGroupBox}"
                                  Grid.Row="3">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Новая роль:" 
                                           VerticalAlignment="Center" 
                                           Margin="5"/>
                                <ComboBox x:Name="cmbChangeRole" 
                                          Width="120" 
                                          Style="{StaticResource CampComboBox}"
                                          DisplayMemberPath="RoleName"
                                          SelectedValuePath="RoleID"/>

                                <Button x:Name="btnChangeRole" 
                                        Content="Сменить роль" 
                                        Style="{StaticResource ActionButton}"
                                        Click="btnChangeRole_Click"/>

                                <Button x:Name="btnToggleUser" 
                                        Content="Переключить" 
                                        Style="{StaticResource ActionButton}"
                                        Click="btnToggleUser_Click"/>

                                <Button x:Name="btnDeleteUser" 
                                        Content="Удалить" 
                                        Style="{StaticResource ActionButton}"
                                        Click="btnDeleteUser_Click"/>
                            </StackPanel>
                        </GroupBox>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <!-- Клиенты -->
            <TabItem Header="Клиенты">
                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="5">
                        <TextBox x:Name="txtCustomerName" 
                                 Width="150" 
                                 Style="{StaticResource CampTextBox}"
                                 ToolTip="ФИО"/>
                        <TextBox x:Name="txtCustomerPhone" 
                                 Width="120" 
                                 Style="{StaticResource CampTextBox}"
                                 ToolTip="Телефон"
                                 Margin="5,0"/>
                        <TextBox x:Name="txtCustomerEmail" 
                                 Width="150" 
                                 Style="{StaticResource CampTextBox}"
                                 ToolTip="Email"
                                 Margin="0,0,5,0"/>
                        <Button x:Name="btnAddCustomer" 
                                Content="Добавить" 
                                Style="{StaticResource ActionButton}"
                                Click="btnAddCustomer_Click"/>
                        <Button x:Name="btnUpdateCustomer" 
                                Content="Изменить" 
                                Style="{StaticResource ActionButton}"
                                Click="btnUpdateCustomer_Click"/>
                        <Button x:Name="btnDeleteCustomer" 
                                Content="Удалить" 
                                Style="{StaticResource ActionButton}"
                                Click="btnDeleteCustomer_Click"/>
                    </StackPanel>

                    <DataGrid x:Name="dgCustomers" 
                              Grid.Row="1"
                              Style="{StaticResource CampDataGrid}"
                              SelectionChanged="dgCustomers_SelectionChanged"/>
                </Grid>
            </TabItem>

            <!-- Места -->
            <TabItem Header="Места">
                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="5">
                        <TextBox x:Name="txtSiteCode" 
                                 Width="80" 
                                 Style="{StaticResource CampTextBox}"
                                 ToolTip="Код"/>
                        <TextBox x:Name="txtSiteName" 
                                 Width="150" 
                                 Style="{StaticResource CampTextBox}"
                                 ToolTip="Название"
                                 Margin="5,0"/>
                        <TextBox x:Name="txtSiteType" 
                                 Width="100" 
                                 Style="{StaticResource CampTextBox}"
                                 ToolTip="Тип"
                                 Margin="0,0,5,0"/>
                        <TextBox x:Name="txtSiteCapacity" 
                                 Width="60" 
                                 Style="{StaticResource CampTextBox}"
                                 ToolTip="Вместимость"/>
                        <TextBox x:Name="txtSitePrice" 
                                 Width="80" 
                                 Style="{StaticResource CampTextBox}"
                                 ToolTip="Цена за ночь"
                                 Margin="5,0"/>
                        <Button x:Name="btnAddSite" 
                                Content="Добавить" 
                                Style="{StaticResource ActionButton}"
                                Click="btnAddSite_Click"/>
                        <Button x:Name="btnUpdateSite" 
                                Content="Изменить" 
                                Style="{StaticResource ActionButton}"
                                Click="btnUpdateSite_Click"/>
                        <Button x:Name="btnDeleteSite" 
                                Content="Удалить" 
                                Style="{StaticResource ActionButton}"
                                Click="btnDeleteSite_Click"/>
                    </StackPanel>

                    <DataGrid x:Name="dgSites" 
                              Grid.Row="1"
                              Style="{StaticResource CampDataGrid}"
                              SelectionChanged="dgSites_SelectionChanged"/>
                </Grid>
            </TabItem>

            <!-- Услуги -->
            <TabItem Header="Услуги">
                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="5">
                        <TextBox x:Name="txtServiceName" 
                                 Width="150" 
                                 Style="{StaticResource CampTextBox}"
                                 ToolTip="Название"/>
                        <TextBox x:Name="txtServiceType" 
                                 Width="100" 
                                 Style="{StaticResource CampTextBox}"
                                 ToolTip="Тип"
                                 Margin="5,0"/>
                        <TextBox x:Name="txtServicePrice" 
                                 Width="80" 
                                 Style="{StaticResource CampTextBox}"
                                 ToolTip="Цена за день"
                                 Margin="0,0,5,0"/>
                        <Button x:Name="btnAddService" 
                                Content="Добавить" 
                                Style="{StaticResource ActionButton}"
                                Click="btnAddService_Click"/>
                        <Button x:Name="btnUpdateService" 
                                Content="Изменить" 
                                Style="{StaticResource ActionButton}"
                                Click="btnUpdateService_Click"/>
                        <Button x:Name="btnDeleteService" 
                                Content="Удалить" 
                                Style="{StaticResource ActionButton}"
                                Click="btnDeleteService_Click"/>
                    </StackPanel>

                    <DataGrid x:Name="dgServices" 
                              Grid.Row="1"
                              Style="{StaticResource CampDataGrid}"
                              SelectionChanged="dgServices_SelectionChanged"/>
                </Grid>
            </TabItem>

            <!-- Бронирования -->
            <TabItem Header="Бронирования">
                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <DataGrid x:Name="dgBookings" 
                              Style="{StaticResource CampDataGrid}"
                              SelectionChanged="dgBookings_SelectionChanged"/>
                    <StackPanel Grid.Row="1" 
                                Orientation="Horizontal" 
                                Margin="5">
                        <ComboBox x:Name="cmbBookingStatus" 
                                  Width="150" 
                                  Height="28"
                                  Margin="5">
                            <ComboBoxItem Content="Booked"/>
                            <ComboBoxItem Content="Confirmed"/>
                            <ComboBoxItem Content="Cancelled"/>
                            <ComboBoxItem Content="Completed"/>
                        </ComboBox>
                        <Button x:Name="btnUpdateBookingStatus" 
                                Content="Изменить статус" 
                                Style="{StaticResource ActionButton}"
                                Click="btnUpdateBookingStatus_Click"/>
                        <Button x:Name="btnDeleteBooking" 
                                Content="Удалить" 
                                Style="{StaticResource ActionButton}"
                                Click="btnDeleteBooking_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- Посещения -->
            <TabItem Header="Посещения">
                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="5">
                        <ComboBox x:Name="cmbVisitCustomer" 
                                  Width="150" 
                                  Style="{StaticResource CampComboBox}"
                                  DisplayMemberPath="FullName"
                                  SelectedValuePath="CustomerID"/>
                        <ComboBox x:Name="cmbVisitSite" 
                                  Width="150" 
                                  Style="{StaticResource CampComboBox}"
                                  DisplayMemberPath="SiteName"
                                  SelectedValuePath="SiteID"
                                  Margin="5,0"/>
                        <DatePicker x:Name="dpVisitStart" 
                                    Height="28"
                                    Margin="0,0,5,0"/>
                        <DatePicker x:Name="dpVisitEnd" 
                                    Height="28"/>
                        <Button x:Name="btnAddVisit" 
                                Content="Добавить" 
                                Style="{StaticResource ActionButton}"
                                Margin="5,0"
                                Click="btnAddVisit_Click"/>
                        <Button x:Name="btnDeleteVisit" 
                                Content="Удалить" 
                                Style="{StaticResource ActionButton}"
                                Click="btnDeleteVisit_Click"/>
                    </StackPanel>

                    <DataGrid x:Name="dgVisits" 
                              Grid.Row="1"
                              Style="{StaticResource CampDataGrid}"/>
                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</Window>