<Window x:Class="SilaLesaWpfApp.View.Window.UserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Пользователь — Сила леса" 
        Height="600" Width="900"
        MinHeight="500" MinWidth="750"
        WindowStartupLocation="CenterScreen"
        Background="#E8F5E9">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Кнопка выхода -->
        <Button x:Name="btnLogout" 
                Grid.Row="0"
                Content="Выйти" 
                Style="{StaticResource ActionButton}"
                HorizontalAlignment="Right"
                Margin="10"
                Click="btnLogout_Click"/>

        <!-- Вкладки -->
        <TabControl x:Name="tabControl" 
                    Grid.Row="1" Grid.RowSpan="2"
                    Style="{StaticResource CampTabControl}"
                    Margin="10,0,10,10">

            <!-- Новое бронирование -->
            <TabItem Header="Новое бронирование">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Клиент и даты -->
                        <GroupBox Header="Клиент и даты" 
                                  Style="{StaticResource CampGroupBox}"
                                  Grid.Row="0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="200"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="Клиент:" 
                                           VerticalAlignment="Center" 
                                           Margin="5"/>
                                <ComboBox x:Name="cmbCustomer" 
                                          Grid.Column="1"
                                          Style="{StaticResource CampComboBox}"
                                          DisplayMemberPath="FullName"
                                          SelectedValuePath="CustomerID"/>

                                <TextBlock Grid.Column="2" 
                                           Text="Заезд:" 
                                           VerticalAlignment="Center" 
                                           Margin="10,5,5,5"/>
                                <DatePicker x:Name="dpCheckIn" 
                                            Grid.Column="3"
                                            Height="28"/>

                                <TextBlock Grid.Column="4" 
                                           Text="Выезд:" 
                                           VerticalAlignment="Center" 
                                           Margin="10,5,5,5"/>
                                <DatePicker x:Name="dpCheckOut" 
                                            Grid.Column="5"
                                            Height="28"/>

                                <Button x:Name="btnSearchSites" 
                                        Grid.Column="6"
                                        Content="Найти места" 
                                        Style="{StaticResource ActionButton}"
                                        Margin="10,0,0,0"
                                        Click="btnSearchSites_Click"/>
                            </Grid>
                        </GroupBox>

                        <!-- Доступные места и услуги -->
                        <Grid Grid.Row="1" Margin="0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="300"/>
                            </Grid.ColumnDefinitions>

                            <!-- Доступные места -->
                            <GroupBox Header="Доступные места" 
                                      Style="{StaticResource CampGroupBox}"
                                      Grid.Column="0">
                                <DataGrid x:Name="dgAvailableSites" 
                                          Style="{StaticResource CampDataGrid}"
                                          Height="250"
                                          SelectionChanged="dgAvailableSites_SelectionChanged"/>
                            </GroupBox>

                            <!-- Доп. услуги -->
                            <GroupBox Header="Доп. услуги" 
                                      Style="{StaticResource CampGroupBox}"
                                      Grid.Column="1">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <ComboBox x:Name="cmbService" 
                                              Grid.Row="0"
                                              Style="{StaticResource CampComboBox}"
                                              DisplayMemberPath="ServiceName"
                                              SelectedValuePath="ServiceID"/>

                                    <StackPanel Grid.Row="1" 
                                                Orientation="Horizontal" 
                                                Margin="0,5">
                                        <TextBlock Text="Количество:" 
                                                   VerticalAlignment="Center" 
                                                   Margin="0,0,5,0"/>
                                        <TextBox x:Name="txtServiceQty" 
                                                 Width="50" 
                                                 Height="24"
                                                 Text="1"
                                                 TextAlignment="Center"/>
                                        <Button x:Name="btnAddService" 
                                                Content="Добавить" 
                                                Style="{StaticResource ActionButton}"
                                                Margin="5,0"
                                                Click="btnAddService_Click"/>
                                        <Button x:Name="btnClearServices" 
                                                Content="Очистить" 
                                                Style="{StaticResource ActionButton}"
                                                Click="btnClearServices_Click"/>
                                    </StackPanel>

                                    <DataGrid x:Name="dgSelectedServices" 
                                              Grid.Row="2"
                                              Style="{StaticResource CampDataGrid}"
                                              Height="150"/>

                                    <Button x:Name="btnCreateBooking" 
                                            Grid.Row="3"
                                            Content="Создать бронирование" 
                                            Style="{StaticResource CampButton}"
                                            HorizontalAlignment="Center"
                                            Margin="0,10"
                                            Click="btnCreateBooking_Click"/>
                                </Grid>
                            </GroupBox>
                        </Grid>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <!-- Мои бронирования -->
            <TabItem Header="Мои бронирования">
                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <DataGrid x:Name="dgMyBookings" 
                              Style="{StaticResource CampDataGrid}"/>
                    <Button x:Name="btnCancelBooking" 
                            Grid.Row="1"
                            Content="Отменить бронирование" 
                            Style="{StaticResource CampButton}"
                            HorizontalAlignment="Left"
                            Margin="5"
                            Click="btnCancelBooking_Click"/>
                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</Window>