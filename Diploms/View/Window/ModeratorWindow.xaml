<Window x:Class="SilaLesaWpfApp.View.Window.ModeratorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Модератор — Сила леса" 
        Height="550" Width="800"
        MinHeight="450" MinWidth="650"
        WindowStartupLocation="CenterScreen"
        Background="#E8F5E9">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель с кнопками -->
        <StackPanel Grid.Row="0" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right"
                    Margin="10">
            <Button x:Name="btnRefresh" 
                    Content="Обновить" 
                    Style="{StaticResource ActionButton}"
                    Click="btnRefresh_Click"/>
            <Button x:Name="btnLogout" 
                    Content="Выйти" 
                    Style="{StaticResource ActionButton}"
                    Click="btnLogout_Click"/>
        </StackPanel>

        <!-- Вкладки -->
        <TabControl x:Name="tabControl" 
                    Grid.Row="1" Grid.RowSpan="2"
                    Style="{StaticResource CampTabControl}"
                    Margin="10,0,10,10">

            <!-- Клиенты -->
            <TabItem Header="Клиенты">
                <Grid Margin="5">
                    <DataGrid x:Name="dgCustomers" 
                              Style="{StaticResource CampDataGrid}"/>
                </Grid>
            </TabItem>

            <!-- Места -->
            <TabItem Header="Места">
                <Grid Margin="5">
                    <DataGrid x:Name="dgSites" 
                              Style="{StaticResource CampDataGrid}"/>
                </Grid>
            </TabItem>

            <!-- Услуги -->
            <TabItem Header="Услуги">
                <Grid Margin="5">
                    <DataGrid x:Name="dgServices" 
                              Style="{StaticResource CampDataGrid}"/>
                </Grid>
            </TabItem>

            <!-- Бронирования -->
            <TabItem Header="Бронирования">
                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <DataGrid x:Name="dgBookings" 
                              Style="{StaticResource CampDataGrid}"
                              SelectionChanged="dgBookings_SelectionChanged"/>
                    <StackPanel Grid.Row="1" 
                                Orientation="Horizontal" 
                                Margin="5">
                        <ComboBox x:Name="cmbStatus" 
                                  Width="150" 
                                  Height="28"
                                  Margin="5">
                            <ComboBoxItem Content="Booked"/>
                            <ComboBoxItem Content="Confirmed"/>
                            <ComboBoxItem Content="Cancelled"/>
                            <ComboBoxItem Content="Completed"/>
                        </ComboBox>
                        <Button x:Name="btnUpdateStatus" 
                                Content="Изменить статус" 
                                Style="{StaticResource ActionButton}"
                                Click="btnUpdateStatus_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</Window>