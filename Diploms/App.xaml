<Application x:Class="SilaLesaWpfApp.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="View/Window/LoginWindow.xaml">
    <Application.Resources>
        <!-- Общие стили для всех окон -->

        <!-- Стиль кнопки -->
        <Style x:Key="CampButton" TargetType="Button">
            <Setter Property="Background" Value="#FAEBD7"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="Black"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <!-- Стиль кнопки действия -->
        <Style x:Key="ActionButton" TargetType="Button" BasedOn="{StaticResource CampButton}">
            <Setter Property="Background" Value="#F5F5DC"/>
            <Setter Property="Padding" Value="10,5"/>
        </Style>

        <!-- Стиль TextBox -->
        <Style x:Key="CampTextBox" TargetType="TextBox">
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="5,3"/>
            <Setter Property="BorderBrush" Value="#999999"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- Стиль ComboBox -->
        <Style x:Key="CampComboBox" TargetType="ComboBox">
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="5,3"/>
        </Style>

        <!-- Стиль DataGrid -->
        <Style x:Key="CampDataGrid" TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="True"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="GridLinesVisibility" Value="All"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#F0F0F0"/>
            <Setter Property="RowBackground" Value="White"/>
            <Setter Property="AlternatingRowBackground" Value="#F5F5F5"/>
        </Style>

        <!-- Стиль GroupBox -->
        <Style x:Key="CampGroupBox" TargetType="GroupBox">
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="5"/>
        </Style>

        <!-- Стиль TabControl -->
        <Style x:Key="CampTabControl" TargetType="TabControl">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
        </Style>

    </Application.Resources>
</Application>